        padding: 0 2rem;
    }
    .mst-gdpr__cookie-settings--cookie-group-container .title-container .title {
        width: auto;
    }
}

.modal-popup.mst-gdpr__cookie-settings--cookie-modal-settings._show {
    z-index: 10001 !important;
}
.modal-popup.mst-gdpr__cookie-settings--cookie-modal-settings._show .modal-inner-wrap {
    background-color: #fff;
    max-height: 90%;
    box-shadow: 0 0 2px 1px rgba(37, 44, 97, 0.15);
}

.modal-popup.mst-gdpr__cookie-settings--cookie-modal-settings._show .modal-inner-wrap .modal-header {
    padding-top: 3rem;
    padding-bottom: 1.2rem;
    padding-left: 3rem;
    padding-right: 3rem;
