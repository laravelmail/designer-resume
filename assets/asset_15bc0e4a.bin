    box-shadow: none !important;
    -webkit-box-shadow: none !important;
}

.modal-popup.mst-gdpr__cookie-settings--cookie-modal-settings._show .modal-inner-wrap .modal-content {
    padding-top: 0;
    padding-bottom: 0;
    padding-left: 3rem;
    padding-right: 3rem;
    border: none !important;
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
    overflow-y: auto;
}

.modal-popup.mst-gdpr__cookie-settings--cookie-modal-settings._show .modal-inner-wrap .modal-footer {
    padding-top: 3rem;
    padding-bottom: 3rem;
    padding-left: 3rem;
